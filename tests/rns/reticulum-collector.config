# Isolated Reticulum instance for the collector in the local pipeline test.
# share_instance = No keeps it from touching any default Reticulum instance on
# this host. The TCP server on loopback is the only interface, and the monitor
# and query instances connect to it.

[reticulum]
  enable_transport = No
  share_instance = No
  panic_on_interface_error = No

[logging]
  loglevel = 3

[interfaces]

  [[test-loopback]]
    type = TCPServerInterface
    interface_enabled = True
    listen_ip = 127.0.0.1
    listen_port = 52010
