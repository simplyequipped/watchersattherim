# Isolated Reticulum instance for the query client in the local pipeline test.
# Connects to the collector's loopback TCP server.

[reticulum]
  enable_transport = No
  share_instance = No
  panic_on_interface_error = No

[logging]
  loglevel = 3

[interfaces]

  [[test-loopback]]
    type = TCPClientInterface
    interface_enabled = True
    target_host = 127.0.0.1
    target_port = 52010
